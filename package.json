{
  "workspaces": [
    "packages/@oveo/*",
    "packages/@oveo/optimizer/packages/*",
    "packages/oveo",
    "tests"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "bun test ./tests/",
    "check": "oxlint",
    "format": "oxfmt",
    "napi-build": "napi build --platform --esm --manifest-path ./packages/@oveo/optimizer/Cargo.toml --package-json-path ./packages/@oveo/optimizer/package.json --output-dir ./packages/@oveo/optimizer"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "rolldown": "^1.1.1",
    "typescript": "^6.0.3"
  }
}
