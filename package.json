{
  "workspaces": [
    "packages/@oveo/*",
    "packages/@oveo/optimizer/packages/*",
    "packages/oveo",
    "tests"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "bun test ./tests/",
    "napi-build": "napi build --platform --esm --manifest-path ./packages/@oveo/optimizer/Cargo.toml --package-json-path ./packages/@oveo/optimizer/package.json --output-dir ./packages/@oveo/optimizer ${NAPI_FLAGS}"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/bun": "^1.3.14",
    "@napi-rs/cli": "^3.6.2",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "^6.0.3",
    "rolldown": "^1.0.2"
  }
}
